import React, { useState } from 'react';

const Header = ({ onSubmit }) => {
  const [productInfo, setProductInfo] = useState('');
  const [backgroundInfo, setBackgroundInfo] = useState('');
  const [selectedImage, setSelectedImage] = useState(null);

  const handleSubmit = () => {
    if (productInfo.trim().split(' ').length < 3 || !selectedImage) {
      alert('Lütfen en az 3 kelimelik ürün bilgisi girin ve bir resim yükleyin.');
      return;
    }

    const formData = new FormData();
    formData.append('productDescription', productInfo);
    formData.append('backgroundDescription', backgroundInfo);
    formData.append('image', selectedImage);

    onSubmit(formData);
  };

  return (
    <div className="min-h-screen bg-gradient-to-b from-gray-900 via-gray-800 to-black text-white px-6 py-16 lg:px-28">
      {/* -------- Slogan -------- */}
      <p className="text-center text-lg sm:text-xl text-teal-400 mb-8 tracking-wide">
        E-ticaret içeriklerinizi yapay zeka ile yeniden tasarlayın!
      </p>

      <div className="flex flex-col lg:flex-row items-start justify-between gap-y-16 lg:gap-x-16">
        {/* -------- Sol Taraf -------- */}
        <div className="flex-1">
          <h1 className="text-5xl xl:text-7xl font-extrabold leading-tight mb-12 text-center lg:text-left">
            Ürünlerinizi <br />
            <span className="bg-gradient-to-r from-teal-500 to-green-500 bg-clip-text text-transparent">
              Baştan Yaratın
            </span>
          </h1>

          <div className="mt-6 space-y-6">
            <input
              type="text"
              placeholder="Ürün ile ilgili açıklayıcı minimum üç kelime yazınız..."
              value={productInfo}
              onChange={(e) => setProductInfo(e.target.value)}
              className="w-full p-5 text-lg bg-gray-800 text-white border border-gray-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
            />

            <input
              type="text"
              placeholder="Arka plan tasarımı için birkaç kelime yazabilirsiniz (isteğe bağlı)"
              value={backgroundInfo}
              onChange={(e) => setBackgroundInfo(e.target.value)}
              className="w-full p-5 text-lg bg-gray-800 text-white border border-gray-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
            />

            <div className="flex gap-8 mt-4 justify-center lg:justify-start">
              <div>
                <input
                  type="file"
                  id="imageUpload"
                  accept="image/*"
                  onChange={(e) => setSelectedImage(e.target.files[0])}
                  hidden
                />
                <label
                  htmlFor="imageUpload"
                  className="inline-block bg-gradient-to-r from-teal-600 to-green-500 text-white px-10 py-4 text-lg rounded-lg cursor-pointer transition-transform hover:scale-110 hover:translate-y-1 shadow-lg"
                >
                  Resim Yükle
                </label>
              </div>
              <button
                onClick={handleSubmit}
                className="bg-gradient-to-r from-teal-600 to-green-500 text-white px-10 py-4 text-lg rounded-lg transition-transform hover:scale-110 hover:translate-y-1 shadow-lg"
              >
                Oluştur
              </button>
            </div>
          </div>
        </div>

        {/* -------- Sağ Taraf -------- */}
        <div className="flex-1 flex flex-col items-center gap-y-8">
          <div className="w-3/4 max-w-md">
            <img
              src="resim.png"
              alt="Örnek Görsel"
              className="w-full rounded-xl shadow-2xl border border-gray-700"
            />
          </div>
          <div className="text-lg leading-relaxed text-center text-gray-300">
            <h2 className="font-bold text-3xl mb-6 text-white">
              Kolayca Üretin ve İyileştirin
            </h2>
            <ul className="list-none space-y-4">
              <li className="flex items-center gap-3">
                <span className="bg-teal-500 w-4 h-4 rounded-full"></span>
                Arka plan değiştirme
              </li>
              <li className="flex items-center gap-3">
                <span className="bg-teal-500 w-4 h-4 rounded-full"></span>
                Görsel kalitesini artırma
              </li>
              <li className="flex items-center gap-3">
                <span className="bg-teal-500 w-4 h-4 rounded-full"></span>
                Ürün başlığı ve açıklama oluşturma
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  );
};

export default Header;
